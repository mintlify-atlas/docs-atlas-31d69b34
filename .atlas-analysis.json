  "keyFeatures": [
    "Multi-organization support with role-based access control",
    "Geospatial data management with Leaflet map visualization",
    "Shapefile import and validation with background workers",
    "Forest patrimony management across hierarchical levels",
    "Biological asset tracking and measurement campaigns",
    "Land accounting and forest area calculations",
    "Comprehensive audit logging system",
    "NextAuth v5 authentication with credential provider"
  ],
